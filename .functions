# ~/.functions — loader for ~/.dotfiles/functions.d/*.sh
# Each fragment is a topic file (one category per file). Add a new file in
# functions.d/ to extend; no edits to this loader required.

_fn_dir="$HOME/.dotfiles/functions.d"
if [[ -d "$_fn_dir" ]]; then
    for _f in "$_fn_dir"/*.sh; do
        [[ -r "$_f" ]] && source "$_f"
    done
    unset _f
fi
unset _fn_dir
