# ~/.commonrc — Cross-platform shell configuration
# Sourced by both bash and zsh on any system.
# Machine-specific config (EDITOR, secrets, etc.) goes in ~/.localrc

# ─── PATH ─────────────────────────────────────────────────────────────────────

export PATH="$HOME/.local/bin:$PATH"
[[ -d "$HOME/.cargo/bin" ]] && export PATH="$PATH:$HOME/.cargo/bin"
export PATH="$PATH:$HOME/.lmstudio/bin"

# ─── SSH agent forwarding (stable symlink for tmux) ─────────────────────────
# When connected via SSH with agent forwarding, each connection creates a new
# socket in /tmp/ssh-*/. Tmux sessions hold the old path, which goes stale on
# reconnect. Fix: maintain a stable symlink that gets updated on each login.

if [[ -n "$SSH_CONNECTION" && -S "$SSH_AUTH_SOCK" && "$SSH_AUTH_SOCK" != "$HOME/.ssh/auth_sock" ]]; then
    ln -sf "$SSH_AUTH_SOCK" "$HOME/.ssh/auth_sock"
    export SSH_AUTH_SOCK="$HOME/.ssh/auth_sock"
fi

# ─── Environment ──────────────────────────────────────────────────────────────

[[ -f "$HOME/.env" ]]     && source "$HOME/.env"
[[ -f "$HOME/.localrc" ]] && source "$HOME/.localrc"

# Export the active dotfiles profile for scripts that branch on it (e.g.
# `dot update` reconciliation). .localrc can override by setting it first.
if [[ -z "$DOTFILES_PROFILE" && -f "$HOME/.dotfiles/.active-profile" ]]; then
    export DOTFILES_PROFILE="$(cat "$HOME/.dotfiles/.active-profile")"
fi

# ─── XDG_RUNTIME_DIR ──────────────────────────────────────────────────────────
# WSL2: PAM sets XDG_RUNTIME_DIR=/run/user/<uid> but systemd never creates it
# and /run/user/ is root-owned, so mkdir fails. Unset it so tools fall back to
# their defaults rather than warning about a missing directory.
if [[ -n "$XDG_RUNTIME_DIR" && ! -d "$XDG_RUNTIME_DIR" ]]; then
    unset XDG_RUNTIME_DIR
fi

# ─── ble.sh (Bash Line Editor) ──────────────────────────────────────────────
# Fish/zsh-style autosuggestions + syntax highlighting for interactive bash.
# Two-step load (the ble.sh-recommended pattern): source with --noattach here,
# then `ble-attach` at the very end of this file — after history, fzf, starship,
# and PROMPT_COMMAND are set — so ble.sh wraps the finished config. Bash +
# interactive only; zsh has its own autosuggestions via .zshrc. Installed by
# scripts/tools/install-blesh.sh into ~/.local/share/blesh.
_blesh="${XDG_DATA_HOME:-$HOME/.local/share}/blesh/ble.sh"
if [[ -n "$BASH_VERSION" && $- == *i* && -r "$_blesh" ]]; then
    source "$_blesh" --noattach
fi

# Filename highlighting: ble.sh's default filename_* faces are blue + underline,
# which makes completion candidates and on-line paths hard to read. Drive its
# colors from LS_COLORS instead (so paths match `ls`/eza) and clear the extra
# underline. Populate LS_COLORS from dircolors' default palette if nothing set
# it yet — without it filename_ls_colors is empty and ble.sh keeps its defaults.
if [[ -n "${BLE_VERSION-}" ]]; then
    [[ -z "$LS_COLORS" ]] && command -v dircolors &>/dev/null && eval "$(dircolors -b)"
    bleopt filename_ls_colors="$LS_COLORS"
    ble-face filename_ls_colors=none
fi

# ─── History ──────────────────────────────────────────────────────────────────

# Two layers: an in-memory list (what ↑ recalls) and the on-disk history file.
# Goal: per-terminal recall. Each shell keeps its OWN in-memory list for the life
# of the session and never imports commands typed in other live terminals — ↑
# shows only what THIS terminal ran (plus history from before it started). Each
# command is still flushed to the shared file immediately, so it survives crashes
# and any NEWLY opened terminal inherits everything; we just never read the file
# back into a running session (that read is what used to make siblings bleed in).
if [[ -n "$BASH_VERSION" ]]; then
    export HISTSIZE=100000                    # in-memory entries
    export HISTFILESIZE=200000                # entries kept on disk
    export HISTCONTROL=ignoreboth:erasedups   # drop space-prefixed, dup, older-dup lines
    export HISTIGNORE='ls:ll:la:cd:..:up:up2:up3:up4:cdr:pwd:gs:tl:wl:wlf:wj:ws:wsc:wsr:wm:wmn:wms:wr:wrf:wxc:wxcs:wxs:wxr:wxp:wxf:wxfr:wxpr:wxprd:wtc:wtc *:wta:wtaa:stk:sta:stj:stn:stt:kcg:kapi:kns:k9:k9s:nvim .:n .:nvim *Snacks.lazygit*:tav:tav *:oc:gra:just:cld:cld -c:clear \&\& cld:clear \&\& cld -c:clear:history:bg:fg:exit:&'
    export HISTTIMEFORMAT='%F %T  '           # record + show timestamps
    shopt -s histappend                       # append on exit instead of overwriting
    shopt -s cmdhist                          # multi-line command → one entry (joined with ;)
    # NOTE: `lithist` is deliberately OFF. It stores multi-line commands with
    # literal embedded newlines, which is exactly what lets entry boundaries blur
    # and merge on reload (a multi-line entry can swallow following commands into
    # one giant blob). Without it, cmdhist joins multi-line commands with `;` —
    # less pretty on recall, but no literal newlines means entries can never merge.
    # Collapse duplicate commands in ~/.bash_history before this shell loads it.
    # erasedups (above) only de-dupes the in-memory list as you type — it never
    # rewrites the file, so history -a from every terminal lets the file pile up
    # stale copies that a fresh shell would bulk-load (bash de-dupes nothing on
    # load). We rewrite the file HERE, during rc, which runs BEFORE the load:
    # plain bash reads HISTFILE after sourcing rc, and ble.sh imports it at attach
    # (end of this file). So no `history -r` reload is needed — one would
    # double-load. Keeps the last occurrence of each command (with its timestamp)
    # and only rewrites when something was actually removed, to limit churn and
    # the race with sibling terminals appending via history -a.
    _hist_dedup_file() {
        local f="${1:-${HISTFILE:-$HOME/.bash_history}}" tmp
        [[ -s "$f" ]] || return 0
        tmp="$(mktemp "${f}.XXXXXX")" || return 0
        if awk '
                /^#[0-9]+$/ { pend=$0; have=1; next }
                { ts[$0]=(have?pend:""); have=0; order[++n]=$0; last[$0]=n }
                END { for (i=1;i<=n;i++) { c=order[i]; if (last[c]==i) { if (ts[c]!="") print ts[c]; print c } } }
            ' "$f" >"$tmp" 2>/dev/null && [[ -s "$tmp" ]] &&
            (( $(wc -l <"$tmp") < $(wc -l <"$f") )); then
            chmod --reference="$f" "$tmp" 2>/dev/null
            mv -f "$tmp" "$f"
        else
            rm -f "$tmp"
        fi
    }
    _hist_dedup_file
    # Flush each command to the shared file as it runs (`history -a`) but never
    # read the file back into this session, so sibling terminals don't bleed into
    # each other's recall. With history_share OFF, ble.sh only adds commands to
    # its in-memory list (it appends to the file on exit), so the manual
    # `history -a` is still needed for prompt-time persistence. The old double-load
    # bug only struck when `-a` was paired with a read (`-n`/`-r`); `-a` alone is
    # safe. BLE_VERSION is already set here: ble.sh was sourced (--noattach) above.
    if [[ -n "${BLE_VERSION-}" ]]; then
        bleopt history_share=0    # was 1: stop importing other live sessions
    fi
    # Set before starship init, which preserves any existing PROMPT_COMMAND.
    PROMPT_COMMAND="history -a; ${PROMPT_COMMAND:+$PROMPT_COMMAND}"
elif [[ -n "$ZSH_VERSION" ]]; then
    HISTSIZE=100000
    SAVEHIST=200000
    setopt HIST_IGNORE_SPACE        # leading-space commands aren't recorded
    setopt HIST_IGNORE_ALL_DUPS     # keep only the most recent copy of a command
    setopt HIST_SAVE_NO_DUPS        # drop older dups when writing the history file
    setopt HIST_FIND_NO_DUPS        # skip earlier dups when searching history
    setopt HIST_REDUCE_BLANKS       # trim superfluous whitespace
    setopt EXTENDED_HISTORY         # record timestamps
    setopt INC_APPEND_HISTORY       # flush each command to the file as it runs…
    unsetopt SHARE_HISTORY          # …but don't import other sessions (Oh My Zsh defaults this on)
    HISTORY_IGNORE='(ls|ll|cd|pwd|exit|clear|history|bg|fg)'
fi

# ─── Aliases & Functions ──────────────────────────────────────────────────────

[[ -f "$HOME/.aliases" ]]   && source "$HOME/.aliases"
[[ -f "$HOME/.functions" ]] && source "$HOME/.functions"

# ─── fzf ──────────────────────────────────────────────────────────────────────

export FZF_COMPLETION_TRIGGER='~~'

if command -v fd &>/dev/null; then
    export FZF_DEFAULT_COMMAND='fd --type f --strip-cwd-prefix --hidden --follow --exclude .git'
    export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
fi

# Key bindings + completion (Ctrl-R fuzzy history, Ctrl-T files, Alt-C cd).
# bash only here — zsh loads `fzf --zsh` from .zshrc after this file is sourced.
if [[ -n "$BASH_VERSION" ]] && command -v fzf &>/dev/null; then
    eval "$(fzf --bash)"
fi

# ─── Tool completions (shell-aware) ──────────────────────────────────────────

# Vendor completions differ per shell. Our custom completions (completions.d/)
# are written once in bash style and shared with zsh via bashcompinit below.
if [[ -n "$BASH_VERSION" ]]; then
    if command -v kubectl &>/dev/null; then
        source <(kubectl completion bash)
        complete -o default -F __start_kubectl k
    fi
    if command -v skaffold &>/dev/null; then
        source <(skaffold completion bash)
    fi
    if command -v just &>/dev/null && [[ -f "$HOME/.just_completion_bash" ]]; then
        source "$HOME/.just_completion_bash"
    fi
elif [[ -n "$ZSH_VERSION" ]]; then
    if command -v kubectl &>/dev/null; then
        source <(kubectl completion zsh)   # `k` inherits via alias expansion
    fi
    if command -v skaffold &>/dev/null; then
        source <(skaffold completion zsh)
    fi
    if [[ -d "$HOME/.docker/completions" ]]; then
        fpath=("$HOME/.docker/completions" $fpath)
    fi
    # Enable bash-style complete/compgen so the shared fragments below work.
    # Requires compinit (run by Oh My Zsh before .commonrc is sourced).
    autoload -U +X bashcompinit && bashcompinit
fi

# Custom completions: written once in bash style, shared with zsh via
# bashcompinit. Alias-name registrations (ta/tk/frk/ws/...) are effectively
# bash-only; on zsh those complete via alias expansion + native completions.
if [[ -d "$HOME/.dotfiles/completions.d" ]]; then
    for _f in "$HOME/.dotfiles/completions.d"/*.sh; do
        [[ -r "$_f" ]] && source "$_f"
    done
    unset _f
fi

# ─── Prompt (starship, bash only for now) ────────────────────────────────────
# Guard on the presence of the starship_precmd function rather than $STARSHIP_SHELL.
# $STARSHIP_SHELL can be inherited from a parent process (stale env var) without
# the shell functions being defined, which caused the prompt to silently break.
# Omarchy double-init is still prevented: if system bashrc already ran
# `starship init bash`, starship_precmd will be defined and we skip cleanly.
# Bash-only until the macOS p10k retirement PR adds zsh.

if ! type starship_precmd &>/dev/null && command -v starship &>/dev/null; then
    if [[ -n "$BASH_VERSION" ]]; then
        eval "$(starship init bash)"
    fi
fi

# ─── ble.sh attach (must stay last) ──────────────────────────────────────────
# Attach now that prompt, completions, fzf, and PROMPT_COMMAND are configured.
# No-op unless ble.sh was sourced above (sets BLE_VERSION); skipped on zsh.
[[ -n "${BLE_VERSION-}" ]] && ble-attach
unset _blesh
