# ~/.commonrc — Cross-platform shell configuration
# Sourced by both bash and zsh on any system.
# Machine-specific config (EDITOR, secrets, etc.) goes in ~/.localrc

# ─── PATH ─────────────────────────────────────────────────────────────────────

export PATH="$HOME/.local/bin:$PATH"
[[ -d "$HOME/.cargo/bin" ]] && export PATH="$PATH:$HOME/.cargo/bin"
export PATH="$PATH:$HOME/.lmstudio/bin"

# ─── SSH agent forwarding (stable symlink for tmux) ─────────────────────────
# When connected via SSH with agent forwarding, each connection creates a new
# socket in /tmp/ssh-*/. Tmux sessions hold the old path, which goes stale on
# reconnect. Fix: maintain a stable symlink that gets updated on each login.

if [[ -n "$SSH_CONNECTION" && -S "$SSH_AUTH_SOCK" && "$SSH_AUTH_SOCK" != "$HOME/.ssh/auth_sock" ]]; then
    ln -sf "$SSH_AUTH_SOCK" "$HOME/.ssh/auth_sock"
    export SSH_AUTH_SOCK="$HOME/.ssh/auth_sock"
fi

# ─── Environment ──────────────────────────────────────────────────────────────

[[ -f "$HOME/.env" ]]     && source "$HOME/.env"
[[ -f "$HOME/.localrc" ]] && source "$HOME/.localrc"

# Export the active dotfiles profile for scripts that branch on it (e.g.
# `dot update` reconciliation). .localrc can override by setting it first.
if [[ -z "$DOTFILES_PROFILE" && -f "$HOME/.dotfiles/.active-profile" ]]; then
    export DOTFILES_PROFILE="$(cat "$HOME/.dotfiles/.active-profile")"
fi

# ─── Aliases & Functions ──────────────────────────────────────────────────────

[[ -f "$HOME/.aliases" ]]   && source "$HOME/.aliases"
[[ -f "$HOME/.functions" ]] && source "$HOME/.functions"

# ─── fzf ──────────────────────────────────────────────────────────────────────

export FZF_COMPLETION_TRIGGER='~~'

if command -v fd &>/dev/null; then
    export FZF_DEFAULT_COMMAND='fd --type f --strip-cwd-prefix --hidden --follow --exclude .git'
    export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
fi

# ─── Tool completions (shell-aware) ──────────────────────────────────────────

# Vendor completions differ per shell. Our custom completions (completions.d/)
# are written once in bash style and shared with zsh via bashcompinit below.
if [[ -n "$BASH_VERSION" ]]; then
    if command -v kubectl &>/dev/null; then
        source <(kubectl completion bash)
        complete -o default -F __start_kubectl k
    fi
    if command -v skaffold &>/dev/null; then
        source <(skaffold completion bash)
    fi
    if command -v just &>/dev/null && [[ -f "$HOME/.just_completion_bash" ]]; then
        source "$HOME/.just_completion_bash"
    fi
elif [[ -n "$ZSH_VERSION" ]]; then
    if command -v kubectl &>/dev/null; then
        source <(kubectl completion zsh)   # `k` inherits via alias expansion
    fi
    if command -v skaffold &>/dev/null; then
        source <(skaffold completion zsh)
    fi
    if [[ -d "$HOME/.docker/completions" ]]; then
        fpath=("$HOME/.docker/completions" $fpath)
    fi
    # Enable bash-style complete/compgen so the shared fragments below work.
    # Requires compinit (run by Oh My Zsh before .commonrc is sourced).
    autoload -U +X bashcompinit && bashcompinit
fi

# Custom completions: written once in bash style, shared with zsh via
# bashcompinit. Alias-name registrations (ta/tk/frk/ws/...) are effectively
# bash-only; on zsh those complete via alias expansion + native completions.
if [[ -d "$HOME/.dotfiles/completions.d" ]]; then
    for _f in "$HOME/.dotfiles/completions.d"/*.sh; do
        [[ -r "$_f" ]] && source "$_f"
    done
    unset _f
fi

# ─── Prompt (starship, bash only for now) ────────────────────────────────────
# Guard on the presence of the starship_precmd function rather than $STARSHIP_SHELL.
# $STARSHIP_SHELL can be inherited from a parent process (stale env var) without
# the shell functions being defined, which caused the prompt to silently break.
# Omarchy double-init is still prevented: if system bashrc already ran
# `starship init bash`, starship_precmd will be defined and we skip cleanly.
# Bash-only until the macOS p10k retirement PR adds zsh.

if ! type starship_precmd &>/dev/null && command -v starship &>/dev/null; then
    if [[ -n "$BASH_VERSION" ]]; then
        eval "$(starship init bash)"
    fi
fi
